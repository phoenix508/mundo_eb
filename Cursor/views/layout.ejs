<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Travel Explorer</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="font-[Poppins] bg-gradient-to-br from-[#1B1B1B] to-[#035AA7] min-h-screen text-white">
    <nav class="fixed w-full bg-black/30 backdrop-blur-md z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <a href="/" class="text-2xl font-bold text-white">TravelWorld</a>
                <div class="space-x-8">
                    <a href="#home" class="text-white hover:text-blue-400 transition-colors">Home</a>
                    <a href="#destinations" class="text-white hover:text-blue-400 transition-colors">Destinations</a>
                    <a href="#contact" class="text-white hover:text-blue-400 transition-colors">Contact</a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        <%- body %>
    </main>

    <footer class="bg-black/30 backdrop-blur-md mt-16">
        <div class="container mx-auto px-6 py-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <h3 class="text-xl font-bold mb-4">TravelWorld</h3>
                    <p class="text-gray-300">Discover the world with us. Your journey begins here.</p>
                </div>
                <div>
                    <h3 class="text-xl font-bold mb-4">Quick Links</h3>
                    <ul class="space-y-2">
                        <li><a href="#home" class="text-gray-300 hover:text-white">Home</a></li>
                        <li><a href="#destinations" class="text-gray-300 hover:text-white">Destinations</a></li>
                        <li><a href="#contact" class="text-gray-300 hover:text-white">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-xl font-bold mb-4">Contact Info</h3>
                    <ul class="space-y-2 text-gray-300">
                        <li>Email: info@travelworld.com</li>
                        <li>Phone: +1 234 567 890</li>
                        <li>Address: 123 Travel Street, World</li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>
</body>
</html> 