<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Travel Explorer</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="font-[Poppins] bg-gradient-to-br from-[#1B1B1B] to-[#035AA7] min-h-screen text-white">
    <nav class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 bg-black/20 backdrop-blur-md rounded-full px-6 py-3 flex gap-8">
        <a href="/" class="text-white hover:text-blue-400 transition-colors">Home</a>
        <a href="#destinations" class="text-white hover:text-blue-400 transition-colors">Destinations</a>
        <a href="/gallery" class="text-white hover:text-blue-400 transition-colors">Gallery</a>
        <a href="#contact" class="text-white hover:text-blue-400 transition-colors">Contact</a>
    </nav>

    <main>
        <%- body %>
    </main>

    <footer class="bg-black/30 backdrop-blur-md mt-16">
        <div class="container mx-auto px-6 py-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <div class="flex items-center">
                        <img src="/images/New_Logo.png" alt="TheMundoTravel Logo" class="w-6 h-6 mr-2 object-contain">
                        <span class="text-xl font-bold">
                            <span class="text-blue-400">The</span><span class="text-white">Mundo</span><span class="text-blue-400">Travel</span>
                        </span>
                    </div>
                    <p class="text-gray-300">Discover the world with us. Your journey begins here.</p>
                </div>
                <div>
                    <h3 class="text-xl font-bold mb-4">Quick Links</h3>
                    <ul class="space-y-2">
                        <li><a href="https://www.youtube.com/@TheMundoTravel" class="text-gray-300 hover:text-white">YouTube</a></li>
                        <li><a href="https://www.expedia.com" class="text-gray-300 hover:text-white">Expedia</a></li>
                        <li><a href="#home" class="text-gray-300 hover:text-white">Home</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-xl font-bold mb-4">Contact Info</h3>
                    <ul class="space-y-2 text-gray-300">
                        <li>Email: casatierra24@gmail.com</li>
                        <li>Phone: +1 413 555 5555</li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
</body>
</html> 